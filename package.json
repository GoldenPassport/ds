{
  "name": "@golden-passport/ds",
  "version": "0.1.0",
  "description": "Golden Passport Design System — React components, Tailwind v4, Headless UI, Lucide icons",
  "author": "Golden Passport",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,md}\" \"*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,md}\" \"*.{ts,js}\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "clean": "rm -rf dist",
    "test-storybook": "vitest run",
    "test-storybook:dark": "vitest run --config vitest.config.dark.ts",
    "test-storybook:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@floating-ui/react": ">=0.26",
    "@headlessui/react": ">=2",
    "lucide-react": ">=0.400",
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "@floating-ui/react": "^0.26.28",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "lucide-react": "^0.469.0",
    "playwright": "^1.59.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.0.0",
  "keywords": [
    "design-system",
    "golden-passport",
    "tailwind",
    "headlessui",
    "lucide",
    "react"
  ],
  "dependencies": {
    "@tippyjs/react": "^4.2.6",
    "tippy.js": "^6.3.7"
  },
  "pnpm": {}
}
