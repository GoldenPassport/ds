{
  "name": "@golden-passport/ds",
  "version": "0.1.0",
  "description": "Golden Passport Design System — React components, Tailwind v4, Headless UI, Lucide icons",
  "author": "Golden Passport",
  "license": "MIT",
  "type": "module",
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles":          "./dist/styles/index.css",
    "./tailwind-preset": "./tailwind.preset.ts"
  },
  "files": ["dist", "tailwind.preset.ts", "tailwind.preset.js"],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build":      "tsup",
    "dev":        "tsup --watch",
    "typecheck":  "tsc --noEmit",
    "lint":       "eslint src --ext .ts,.tsx",
    "clean":      "rm -rf dist",
    "storybook":  "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react":               ">=18",
    "react-dom":           ">=18",
    "@headlessui/react":   ">=2",
    "@floating-ui/react":  ">=0.26",
    "lucide-react":        ">=0.400",
    "tailwindcss":         ">=4"
  },
  "devDependencies": {
    "@floating-ui/react":                    "^0.26.0",
    "@fontsource/dm-sans":                   "^5.0.0",
    "@fontsource/jetbrains-mono":            "^5.0.0",
    "@fontsource/plus-jakarta-sans":         "^5.0.0",
    "@headlessui/react":                     "^2.2.0",
    "@storybook/addon-a11y":                 "^8.6.0",
    "@storybook/addon-essentials":           "^8.6.0",
    "@storybook/addon-themes":               "^8.6.0",
    "@storybook/react-vite":                 "^8.6.0",
    "@tailwindcss/vite":                     "^4.0.0",
    "@types/react":                          "^18.3.0",
    "@types/react-dom":                      "^18.3.0",
    "@vitejs/plugin-react":                  "^4.3.0",
    "lucide-react":                          "^0.469.0",
    "react":                                 "^18.3.1",
    "react-dom":                             "^18.3.1",
    "storybook":                             "^8.6.0",
    "tailwindcss":                           "^4.0.0",
    "tsup":                                  "^8.0.0",
    "typescript":                            "^5.4.0",
    "vite":                                  "^6.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "keywords": ["design-system", "golden-passport", "tailwind", "headlessui", "lucide", "react"]
}
